# Configuración del Servicio de Notificaciones
PORT=50051

# Configuración de Base de Datos PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=notificaciones_db

# Resend (email notifications)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=onboarding@resend.dev

# Contact Resolver (cómo se obtiene el email del usuario)
# Opción A — env var (dev/default): todos los emails van a DEFAULT_USER_EMAIL
DEFAULT_USER_EMAIL=destinatario@example.com
# Opción B — gRPC (prod): llama al User Service para obtener el email real
# USER_SERVICE_HOST=user-service:9090
